#include<stdio.h>

int main(){
    int a[10], n, i, mid, key, found = 0;
    int low = 0, high;

    printf("Enter number of elements : ");
    scanf("%d", &n);

    high = n - 1;

    printf("Enter array elements in sorted order : \n");
    for(i = 0; i < n; i++){
        scanf("%d", &a[i]);
    }

    printf("Enter key to search : ");
    scanf("%d", &key);

    while(low <= high){
        mid = (low + high) / 2;

        if(a[mid] == key){
            printf("Element found at index %d\n", mid);
            found = 1;
            break;
        }
        else if(a[mid] < key){
            low = mid + 1;
        }
        else{
            high = mid - 1;
        }
    }

    if(found == 0){
        printf("Element not found in the array");
    }

    return 0;
}
